# ── ldoce5-api (port 5050) ──────────────────────────────────────────────────
LDOCE5_MDX_PATH=/data/dict/Longman Dictionary Of Contemporary English 5th.mdx
LDOCE5_MDD_PATH=/data/dict/Longman Dictionary Of Contemporary English 5th.mdd
API_HOST=0.0.0.0
API_PORT=5050

# LLM sense disambiguation — leave empty to disable
LLM_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ── anki-writer (port 5051) ─────────────────────────────────────────────────
COLLECTION_PATH=/data/anki/collection.anki2
ANKI_SYNC_URL=http://localhost:8080/
ANKI_SYNC_USER=anki
ANKI_SYNC_PASSWORD=anki
LDOCE5_API_URL=http://localhost:5050
DECK_NAME=ODH
NOTE_TYPE_NAME=ODH
