# ============================================================
# iPhone-Anki Sync API — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Required: Absolute path to the LDOCE5 .mdx file on this machine
LDOCE5_MDX_PATH=/root/anki/dict/'Longman Dictionary Of Contemporary English 5th.mdx'

# Optional: Absolute path to the LDOCE5 .mdd audio file (default: disabled)
# When set, British pronunciation audio will be uploaded to Anki automatically
LDOCE5_MDD_PATH=

# Optional: AnkiConnect URL (default: http://localhost:8765)
# Change only if AnkiConnect runs on a different host/port
ANKI_CONNECT_URL=http://localhost:8765

# Optional: Anki deck name to add cards to (default: ODH)
DECK_NAME=ODH

# Optional: Anki note type name (default: ODH)
# Fields must match: word, pronunciation, definition, sentence, audio, extrainfo, url
NOTE_TYPE_NAME=ODH

# Optional: API server bind address (default: 0.0.0.0)
API_HOST=0.0.0.0

# Optional: API server port (default: 5050)
API_PORT=5050

# ============================================================
# LLM Sense Disambiguation (optional)
# When LLM_API_KEY is set and the request includes a "sentence"
# field, the API will call the LLM to pick the best matching
# dictionary sense for the word in context.
# Leave LLM_API_KEY empty to disable AI disambiguation entirely.
# ============================================================

# LLM API key — leave empty to skip AI logic
LLM_API_KEY=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

# LLM service endpoint (OpenAI-compatible)
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model ID to use for sense disambiguation
LLM_MODEL=meta/llama-3.3-70b-instruct
