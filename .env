# ============================================================
# iPhone-Anki Sync API — Local Environment
# ============================================================

# Required: Absolute path to the LDOCE5 .mdx file
LDOCE5_MDX_PATH=/root/anki/dict/'Longman Dictionary Of Contemporary English 5th.mdx'
# Optional: Absolute path to the LDOCE5 .mdd audio file
LDOCE5_MDD_PATH=/root/anki/dict/'Longman Dictionary Of Contemporary English 5th.mdd'

# AnkiConnect URL
ANKI_CONNECT_URL=http://localhost:8765

# Anki deck name
DECK_NAME=ODH

# Anki note type name
NOTE_TYPE_NAME=ODH

# API server
API_HOST=0.0.0.0
API_PORT=5050

# ============================================================
# LLM Sense Disambiguation
# ============================================================

LLM_API_KEY=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
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
